# 环境变量模板 - 复制为 .env 使用
# cp .env.example .env

# ==================== 数据库 ====================
DATABASE_TYPE=postgresql
# 支持: postgresql, mysql, mongodb, sqlite
DATABASE_URL=postgresql+asyncpg://amazing:amazing123@localhost:5432/amazing
# MySQL: mysql+aiomysql://amazing:amazing123@localhost:3306/amazing
# MongoDB: mongodb://amazing:amazing123@localhost:27017/amazing
# SQLite: sqlite+aiosqlite:///./dev.db

DB_USER=amazing
DB_PASSWORD=amazing123
DB_HOST=localhost
DB_PORT=5432
DB_NAME=amazing

# ==================== Redis ====================
REDIS_URL=redis://localhost:6379/0

# ==================== MinIO / S3 ====================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=amazing-data

# ==================== 服务端口 ====================
API_GATEWAY_PORT=8000
FRONTEND_PORT=3000
COMMON_SERVICE_PORT=8001
COMPUTE_SERVICE_PORT=8002
DATA_SERVICE_PORT=8003
TRAINING_SERVICE_PORT=8004
MODEL_SERVICE_PORT=8005

# ==================== AI 工具链 ====================
AI_TOOL=claude
# 支持: claude, codex, codex-desktop
CLAUDE_API_KEY=
CODEX_API_KEY=

# ==================== 安全 ====================
JWT_SECRET=your-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ==================== 监控 ====================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_PASSWORD=admin123

# ==================== 部署模式 ====================
DEPLOY_MODE=local
# 支持: local, docker, k8s, offline
