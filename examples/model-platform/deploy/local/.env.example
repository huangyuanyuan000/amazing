# MongoDB 配置
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DB=logs
MONGODB_USER=admin
MONGODB_PASSWORD=admin123

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
