# 服务端口
COMMON_SERVICE_PORT=8001
DATA_SERVICE_PORT=8002
TRAINING_SERVICE_PORT=8003
COMPUTE_SERVICE_PORT=8004
MODEL_SERVICE_PORT=8005
API_GATEWAY_PORT=8000
